<?xml version="1.0"?>
<launch>
  <!-- 平安城市比赛场地启动文件 -->
  <!-- 模型路径设置：包含自定义垃圾桶/楼宇/人群模型 -->
  <env name="GAZEBO_MODEL_PATH"
       value="$(find turtlebot3_gazebo)/models:$(optenv GAZEBO_MODEL_PATH)"/>

  <arg name="model" default="$(env TURTLEBOT3_MODEL)" doc="model type [burger, waffle, waffle_pi]"/>
  <arg name="x_pos" default="-1.5"/>
  <arg name="y_pos" default="-1.5"/>
  <arg name="z_pos" default="0.0"/>

  <!-- 加载平安城市比赛场地 -->
  <include file="$(find gazebo_ros)/launch/empty_world.launch">
    <arg name="world_name" value="$(find turtlebot3_gazebo)/worlds/safe_city.world"/>
    <arg name="paused" value="false"/>
    <arg name="use_sim_time" value="true"/>
    <arg name="gui" value="true"/>
    <arg name="headless" value="false"/>
    <arg name="debug" value="false"/>
  </include>

  <!-- 加载 TurtleBot3 机器人 -->
  <param name="robot_description"
         command="$(find xacro)/xacro --inorder $(find turtlebot3_description)/urdf/turtlebot3_$(arg model).urdf.xacro" />

  <node name="spawn_urdf" pkg="gazebo_ros" type="spawn_model"
        args="-urdf -model turtlebot3_$(arg model) -x $(arg x_pos) -y $(arg y_pos) -z $(arg z_pos) -param robot_description" />
</launch>
