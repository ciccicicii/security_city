<?xml version="1.0"?>
<sdf version="1.6">
  <world name="test">

    <light name="sun" type="directional">
      <cast_shadows>1</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <attenuation><range>1000</range><constant>0.9</constant><linear>0.01</linear><quadratic>0.001</quadratic></attenuation>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <include><uri>model://ground_plane</uri></include>

    <model name="boundary_line">
      <static>true</static>
      <link name="n"><pose>0 2.0 0.001 0 0 0</pose><visual name="v"><geometry><box><size>4.0 0.02 0.002</size></box></geometry><material><ambient>0.15 0.15 0.15 1.0</ambient></material></visual></link>
      <link name="s"><pose>0 -2.0 0.001 0 0 0</pose><visual name="v"><geometry><box><size>4.0 0.02 0.002</size></box></geometry><material><ambient>0.15 0.15 0.15 1.0</ambient></material></visual></link>
      <link name="e"><pose>2.0 0 0.001 0 0 0</pose><visual name="v"><geometry><box><size>0.02 4.0 0.002</size></box></geometry><material><ambient>0.15 0.15 0.15 1.0</ambient></material></visual></link>
      <link name="w"><pose>-2.0 0 0.001 0 0 0</pose><visual name="v"><geometry><box><size>0.02 4.0 0.002</size></box></geometry><material><ambient>0.15 0.15 0.15 1.0</ambient></material></visual></link>
    </model>

    <model name="track_outer">
      <static>true</static>
      <link name="top"><pose>0 2.0 0.15 0 0 0</pose>
        <visual name="v"><geometry><box><size>4.0 0.040 0.3</size></box></geometry>
        <material><ambient>0.88 0.88 0.88 1.0</ambient></material></visual>
        <collision name="c"><geometry><box><size>4.0 0.040 0.3</size></box></geometry></collision></link>
      <link name="bottom"><pose>0 -2.0 0.15 0 0 0</pose>
        <visual name="v"><geometry><box><size>4.0 0.040 0.3</size></box></geometry>
        <material><ambient>0.88 0.88 0.88 1.0</ambient></material></visual>
        <collision name="c"><geometry><box><size>4.0 0.040 0.3</size></box></geometry></collision></link>
      <link name="left"><pose>-2.0 0 0.15 0 0 0</pose>
        <visual name="v"><geometry><box><size>0.040 4.0 0.3</size></box></geometry>
        <material><ambient>0.88 0.88 0.88 1.0</ambient></material></visual>
        <collision name="c"><geometry><box><size>0.040 4.0 0.3</size></box></geometry></collision></link>
      <link name="right"><pose>2.0 0 0.15 0 0 0</pose>
        <visual name="v"><geometry><box><size>0.040 4.0 0.3</size></box></geometry>
        <material><ambient>0.88 0.88 0.88 1.0</ambient></material></visual>
        <collision name="c"><geometry><box><size>0.040 4.0 0.3</size></box></geometry></collision></link>
    </model>

    <model name="track_inner">
      <static>true</static>
      <link name="top"><pose>0 1.3 0.15 0 0 0</pose>
        <visual name="v"><geometry><box><size>2.6 0.040 0.3</size></box></geometry>
        <material><ambient>0.82 0.82 0.82 1.0</ambient></material></visual>
        <collision name="c"><geometry><box><size>2.6 0.040 0.3</size></box></geometry></collision></link>
      <link name="bottom"><pose>0 -1.3 0.15 0 0 0</pose>
        <visual name="v"><geometry><box><size>2.6 0.040 0.3</size></box></geometry>
        <material><ambient>0.82 0.82 0.82 1.0</ambient></material></visual>
        <collision name="c"><geometry><box><size>2.6 0.040 0.3</size></box></geometry></collision></link>
      <link name="left"><pose>-1.3 0 0.15 0 0 0</pose>
        <visual name="v"><geometry><box><size>0.040 2.6 0.3</size></box></geometry>
        <material><ambient>0.82 0.82 0.82 1.0</ambient></material></visual>
        <collision name="c"><geometry><box><size>0.040 2.6 0.3</size></box></geometry></collision></link>
      <link name="right"><pose>1.3 0 0.15 0 0 0</pose>
        <visual name="v"><geometry><box><size>0.040 2.6 0.3</size></box></geometry>
        <material><ambient>0.82 0.82 0.82 1.0</ambient></material></visual>
        <collision name="c"><geometry><box><size>0.040 2.6 0.3</size></box></geometry></collision></link>
    </model>

    <model name="track_floor">
      <static>true</static>
      <link name="f"><pose>0 0 0.0005 0 0 0</pose>
        <visual name="v"><geometry><box><size>3.96 3.96 0.001</size></box></geometry>
        <material><ambient>0.35 0.35 0.35 1.0</ambient></material></visual></link>
    </model>

    <model name="island_floor">
      <static>true</static>
      <link name="f"><pose>0 0 0.0008 0 0 0</pose>
        <visual name="v"><geometry><box><size>2.60 2.60 0.001</size></box></geometry>
        <material><ambient>0.7 0.7 0.65 1.0</ambient></material></visual></link>
    </model>

    <gravity>0 0 -9.8</gravity>
    <physics name="default_physics" default="0" type="ode">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1</real_time_factor>
      <real_time_update_rate>1000</real_time_update_rate>
    </physics>
    <scene><ambient>0.4 0.4 0.4 1</ambient><background>0.7 0.7 0.7 1</background><shadows>1</shadows></scene>
  </world>
</sdf>